# StreamTrack Environment Variables
# Copy this file to .env and fill in your values

# ===================
# Backend Configuration
# ===================

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/streamtrack

# TMDB API (get from themoviedb.org)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_READ_ACCESS_TOKEN=your_tmdb_read_access_token_here

# Firebase Admin SDK (CRITICAL for /api/auth routes)
# Option 1: Path to service account key file (REQUIRED for auth to work)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Option 2: Service account key as JSON string (alternative to file)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated origins allowed to call backend APIs
ALLOWED_ORIGINS=http://localhost:4200

# ===================
# Frontend Configuration  
# ===================

# Firebase Client SDK (from Firebase Console)
NG_APP_FIREBASE_API_KEY=your_firebase_api_key
NG_APP_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NG_APP_FIREBASE_PROJECT_ID=your_project_id
NG_APP_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NG_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NG_APP_FIREBASE_APP_ID=your_app_id
