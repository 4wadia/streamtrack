{
    "name": "streamtrack-backend",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun --watch src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "start": "bun run dist/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts",
        "test": "bun test"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "express": "^4.22.1",
        "firebase-admin": "^13.7.0",
        "mongoose": "^8.23.0"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^22.19.15",
        "@types/supertest": "^6.0.3",
        "supertest": "^7.2.2",
        "typescript": "^5.9.3"
    }
}