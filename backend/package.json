{
    "name": "streamtrack-backend",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "bun run --env-file ../.env scripts/check-env.ts && bun run --env-file ../.env --watch src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "start": "bun run --env-file ../.env dist/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src --ext .ts",
        "test": "bun test",
        "check-env": "bun run --env-file ../.env scripts/check-env.ts"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.21.2",
        "firebase-admin": "^13.6.0",
        "mongoose": "^8.9.5"
    },
    "devDependencies": {
        "@types/bun": "^1.3.8",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/node": "^22.10.7",
        "@types/supertest": "^6.0.3",
        "supertest": "^7.2.2",
        "typescript": "^5.7.3"
    }
}
